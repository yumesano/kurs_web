# Application
PROJECT_NAME="Stripe Subscription API"
SECRET_KEY=your-super-secret-key-min-32-characters-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/stripe_api
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/stripe_api

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Frontend
FRONTEND_URL=http://localhost:3000

# First admin user
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=admin123456
